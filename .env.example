# GraftDesk Environment Configuration Example
PORT=3000
NODE_ENV=development

# Database Credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=roto@123
DB_NAME=graftdesk_db

# Alternative Database Connection URL
MYSQL_URL=mysql://root:password@localhost:3306/graftdesk_db
DATABASE_URL=mysql://root:password@localhost:3306/graftdesk_db

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# Super Admin CLI Seed Credentials (for npm run create-super-admin)
ADMIN_EMAIL=superadmin@graftdesk.com
ADMIN_PASSWORD=password123
ADMIN_NAME=Platform Super Admin
ADMIN_PHONE=+15550000000

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage Provider Abstraction (local, s3, cloudinary)
STORAGE_PROVIDER=local
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI Scalp Analysis
GEMINI_API_KEY=

# Nodemailer / Email Settings
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_RECIPIENTS=admin@graftdesk.com,sales@graftdesk.com,support@graftdesk.com
